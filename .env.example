# --- Copy to ".env" and fill in (do not commit .env) ---

# Neon Postgres connection string (from Neon dashboard — "Connection string")
# Use the "psql" or "Node.js" URI. Must include ssl (Neon provides ?sslmode=require).
# Use double quotes — URLs with & break unquoted lines in .env
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Random secret for signing login cookies (any long random string)
JWT_SECRET=replace-with-a-long-random-secret

# API server port (must match vite proxy target in vite.config.ts)
API_PORT=3001

# Production: trust X-Forwarded-* from reverse proxy (number of hops, usually 1)
# TRUST_PROXY_HOPS=1

# Max JSON body size for API (default 2mb in production, 25mb in dev)
# JSON_BODY_LIMIT=2mb

# Browser origin(s) for CORS — comma-separated. In development, LAN IPs (192.168.x.x) are also allowed.
CLIENT_ORIGIN=http://localhost:8080

# Frontend: call API through Vite proxy in dev (see vite.config.ts → /api → localhost:3001)
VITE_API_BASE_URL=/api
# Production frontend (Vercel) should point to your API domain, e.g.
# VITE_API_BASE_URL=https://api.portfolioforge.uk

# --- Billing ---
# strict = must pay before first publish | freemium = 1 free portfolio + Glass theme
BILLING_MODE=freemium

# How to get paid (Namibia: Stripe often unavailable — use manual EFT and/or PayPal)
# Auto-pick: Stripe if keys+prices set → else PayPal if set → else manual EFT
# PAYMENT_PROVIDER=stripe
# PAYMENT_PROVIDER=paypal
PAYMENT_PROVIDER=manual

# --- Stripe (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PREMIUM=

# --- PayPal (optional — business account at paypal.com) ---
# Use sandbox for testing; set PAYPAL_MODE=live only in production.
# PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Charged in PAYPAL_CURRENCY (often USD)
PAYPAL_AMOUNT_BASIC=19.00
PAYPAL_AMOUNT_PREMIUM=49.00
PAYPAL_CURRENCY=USD

# --- Manual bank transfer (recommended for Namibia) ---
# Real bank details belong in .env only — never commit them (this file is a template).
BILLING_BANK_NAME=
BILLING_ACCOUNT_NAME=
BILLING_ACCOUNT_NUMBER=
BILLING_BRANCH=
BILLING_MANUAL_NOTE=Email proof of payment with your account email and which plan (Basic or Premium).
BILLING_CONTACT_EMAIL=

# Optional display strings (shown on landing + billing)
# BILLING_DISPLAY_CURRENCY=USD
# BILLING_PRICE_HINT_BASIC=USD $19 (once-off)
# BILLING_PRICE_HINT_PREMIUM=USD $49 (once-off)

# Dev only: POST /billing/dev-set-tier (never enable in production)
# BILLING_DEV_BYPASS=true
# VITE_BILLING_DEV_BYPASS=true
